{
  "name": "@agustin/aqus",
  "version": "0.2.0",
  "description": "Aqus design system — Retro-Aero × Modern React component library",
  "type": "module",
  "main": "./dist/aqus.cjs.js",
  "module": "./dist/aqus.es.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./dist/aqus.es.js",
      "require": "./dist/aqus.cjs.js"
    },
    "./styles.css": "./styles.css"
  },
  "bin": {
    "aqus": "./bin/aqus.js"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "lib",
    "styles.css",
    "assets/fonts",
    "docs",
    "SKILL.md",
    "postinstall.js",
    "_adherence.oxlintrc.json"
  ],
  "sideEffects": ["*.css"],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "postinstall": "node postinstall.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LagoJournal/Aqus.git"
  },
  "author": "Agustin Lago <lagoagustindev@gmail.com>",
  "keywords": ["design-system", "react", "aqua", "retro-aero", "component-library"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
